# APISentinel Environment Configuration
# Copy to .env and fill in values — never commit .env to version control

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=info            # debug | info | warn | error

# ── Crawl Defaults ───────────────────────────────────────────────────────
DEFAULT_MAX_DEPTH=4
DEFAULT_MAX_PAGES=150
DEFAULT_DELAY_MS=400
DEFAULT_CRAWL_MODE=auto   # static | puppeteer | auto

# ── Puppeteer ─────────────────────────────────────────────────────────────
# Set these if Puppeteer can't find Chromium automatically
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ── Validation ────────────────────────────────────────────────────────────
VALIDATE_KEYS=true
VALIDATE_CONCURRENCY=3
VALIDATE_DELAY_MS=600

# ── Storage ───────────────────────────────────────────────────────────────
# DB_PATH=/custom/path/sentinel.db  (default: ~/.api-sentinel/sentinel.db)

# ── Reporting ─────────────────────────────────────────────────────────────
# REPORT_OUTPUT_DIR=/custom/reports  (default: ~/APISentinel-Reports)
